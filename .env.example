# Copy to .env locally. Never commit real values.
NODE_ENV=development
APP_BASE_URL=http://localhost:3000
PORT=3000
DATABASE_URL=mysql://USER:PASSWORD@HOST:3306/cp_future_admin
SESSION_SECRET=change-me-minimum-32-characters
COOKIE_SECURE=false
INITIAL_ADMIN_USERNAME=owner
INITIAL_ADMIN_PASSWORD=change-me-on-first-login
INTEGRATION_MODE=mock
N8N_LIVE_ENABLED=false
N8N_BASE_URL=
N8N_WEBHOOK_BASE_PATH=webhook
N8N_CONTENT_WEBHOOK_PATH=future-foresight/content-generation
N8N_CREATIVE_IMAGE_WEBHOOK_PATH=future-foresight/creative-image-generation
N8N_CREATIVE_VIDEO_WEBHOOK_PATH=future-foresight/creative-video-generation
N8N_PUBLISH_WEBHOOK_PATH=future-foresight/publish-dry-run
N8N_WEBHOOK_SECRET=
N8N_API_KEY=
PLATFORM_CALLBACK_SECRET=change-me-minimum-32-characters
META_PUBLISHING_ENABLED=false
META_APP_ID=
META_FACEBOOK_PAGE_ID=
META_INSTAGRAM_USER_ID=
META_ACCESS_TOKEN=
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
FILE_STORAGE_DRIVER=local
FILE_STORAGE_PATH=./storage
PUBLIC_ASSET_BASE_URL=
MAX_UPLOAD_MB=25
LOG_LEVEL=info
