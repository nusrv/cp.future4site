{
  "name": "future-foresight-admin",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server/index.ts",
    "dev:client": "vite --host 0.0.0.0",
    "build": "npm run typecheck && vite build && tsc -p tsconfig.server.json",
    "start": "node dist/server/index.js",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.server.json --noEmit",
    "lint": "eslint .",
    "test": "vitest run --config vitest.config.ts",
    "test:e2e": "playwright test",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx scripts/seed.ts",
    "db:purge-synthetic": "tsx scripts/purge-synthetic.ts",
    "admin:bootstrap": "tsx scripts/bootstrap-admin.ts",
    "secret:scan": "node scripts/secret-scan.mjs",
    "n8n:build-workflows": "node scripts/n8n-workflow-program.mjs",
    "n8n:check-workflows": "node scripts/check-n8n-workflows.mjs",
    "n8n:push-workflows": "node scripts/push-n8n-workflows.mjs",
    "n8n:verify-workflows": "node scripts/verify-n8n-workflows.mjs",
    "n8n:export-workflow": "node scripts/export-n8n-workflow.mjs",
    "audit:deps": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.22.0",
    "@tanstack/react-query": "^5.59.16",
    "argon2": "^0.41.1",
    "fastify": "^4.28.1",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.2",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.14.0",
    "globals": "^15.12.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.4"
  },
  "prisma": {
    "seed": "tsx scripts/seed.ts"
  }
}
